# ============================================================
# Data Seekers – Panam NoSQL Project
# .env.example — Plantilla de variables de entorno
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores según tu entorno local
#   3. NUNCA subas el archivo .env a git (ya está en .gitignore)
# ============================================================

# ── MongoDB ─────────────────────────────────────────────────
# Si usas Docker (docker-compose.yml), deja los valores por defecto.
# Si usas MongoDB Atlas, pega aquí tu connection string completo.
MONGO_URI=mongodb://admin:password@localhost:27017/
MONGO_DB=panam_nosql

# ── Cassandra ───────────────────────────────────────────────
CASSANDRA_HOST=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=panam_nosql
# Descomenta si tu Cassandra tiene autenticación habilitada:
# CASSANDRA_USER=cassandra
# CASSANDRA_PASSWORD=cassandra

# ── API REST (FastAPI) ──────────────────────────────────────
# Host: 0.0.0.0 escucha en todas las interfaces (recomendado).
# Si solo quieres acceso desde tu máquina, usa 127.0.0.1.
API_HOST=0.0.0.0
API_PORT=8000

# ── Rutas de Datos ──────────────────────────────────────────
# Relativas a la raíz del proyecto. No cambiar salvo que muevas los CSVs.
DATA_DIR=data/raw
OUTPUT_DIR=data/processed

# ── Jupyter ─────────────────────────────────────────────────
# Token de acceso a Jupyter Notebook (déjalo vacío para modo sin contraseña local)
JUPYTER_TOKEN=
